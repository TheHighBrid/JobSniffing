     return FillResult(False, "select", f"option {answer!r} was not found")
 
 
+def _visible(locator: Any) -> bool:
+    try:
+        return bool(locator.is_visible())
+    except Exception:  # noqa: BLE001
+        return True
+
+
+def _locator_value(locator: Any) -> str:
+    values: list[str] = []
+    for reader in (
+        lambda: locator.input_value(),
+        lambda: locator.get_attribute("value"),
+        lambda: locator.inner_text(),
+        lambda: locator.get_attribute("aria-label"),
+        lambda: locator.get_attribute("data-value"),
+    ):
+        try:
+            value = str(reader() or "").strip()
+        except Exception:  # noqa: BLE001
+            continue
+        if value:
+            values.append(value)
+    try:
+        state = locator.evaluate(
+            """el => {
+              const root = el.closest(
+                '[data-automation-id*="formField"], [data-field], .field-wrapper, ' +
+                '[class*="select__control"], [class*="select-container"], ' +
+                '[class*="field-wrapper"], [class*="application-field"]'
+              ) || el.parentElement;
+              const hidden = Array.from(root?.querySelectorAll('input[type="hidden"]') || [])
+                .map(input => input.value || '').filter(Boolean).join(' ');
+              return [el.textContent || '', root?.textContent || '', hidden].join(' ');
+            }"""
+        )
+        if state:
+            values.append(str(state))
+    except Exception:  # noqa: BLE001
+        pass
+    return " ".join(values)
+
+
+def _contains_answer(displayed: str, answer: str) -> bool:
+    shown = normalize_text(displayed)
+    target = normalize_text(answer)
+    return bool(shown and target and f" {target} " in f" {shown} ")
+
+
+def _nth(locator: Any, index: int) -> Any:
+    try:
+        return locator.nth(index)
+    except Exception:  # noqa: BLE001
+        return locator
+
+
+def _combobox_options(scope: Any, combobox: Any) -> list[tuple[Any, str, str]]:
+    selectors: list[str] = []
+    for attr in ("aria-controls", "aria-owns"):
+        try:
+            controls = str(combobox.get_attribute(attr) or "").strip()
+        except Exception:  # noqa: BLE001
+            controls = ""
+        if controls:
+            selectors.append(f"#{controls} [role='option']")
+    selectors.extend(("[role='listbox'] [role='option']", "[role='option']"))
+
+    for selector in selectors:
+        try:
+            locator = scope.locator(selector)
+            total = int(locator.count())
+        except Exception:  # noqa: BLE001
+            continue
+        records: list[tuple[Any, str, str]] = []
+        for index in range(total):
+            option = _nth(locator, index)
+            if not _visible(option):
+                continue
+            label = ""
+            value = ""
+            for reader in (
+                lambda: option.inner_text(),
+                lambda: option.get_attribute("aria-label"),
+                lambda: option.get_attribute("data-value"),
+                lambda: option.get_attribute("value"),
+            ):
+                try:
+                    candidate = str(reader() or "").strip()
+                except Exception:  # noqa: BLE001
+                    continue
+                if candidate and not label:
+                    label = candidate
+            for name in ("data-value", "value"):
+                try:
+                    candidate = str(option.get_attribute(name) or "").strip()
+                except Exception:  # noqa: BLE001
+                    candidate = ""
+                if candidate:
+                    value = candidate
+                    break
+            if label or value:
+                records.append((option, label or value, value or label))
+        if records:
+            return records
+    return []
+
+
+def _match_combobox_option(options: list[tuple[Any, str, str]], answer: str) -> tuple[Any, str, str] | None:
+    target = normalize_text(answer)
+    exact = [item for item in options if target in {normalize_text(item[1]), normalize_text(item[2])}]
+    if len(exact) == 1:
+        return exact[0]
+    fuzzy = [
+        item for item in options
+        if target and (
+            target in normalize_text(item[1])
+            or normalize_text(item[1]) in target
+            or target in normalize_text(item[2])
+            or normalize_text(item[2]) in target
+        )
+    ]
+    return fuzzy[0] if len(fuzzy) == 1 else None
+
+
+def _close_combobox(combobox: Any) -> None:
+    for key in ("Escape", "Tab"):
+        try:
+            combobox.press(key)
+            return
+        except Exception:  # noqa: BLE001
+            continue
+
+
